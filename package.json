{
  "name": "myt-tts-winui",
  "version": "0.2.0",
  "description": "MytimesXR multi-provider desktop text-to-speech client",
  "author": "MytimesXR",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "icons": "electron scripts/render-icons.js",
    "start": "electron .",
    "check:public": "node scripts/audit-public-package.js",
    "check:packaged": "node scripts/audit-packaged-app.js release",
    "pack": "electron-builder --win --x64 --dir",
    "dist": "electron-builder --win portable zip --x64 --publish never",
    "pack:mac": "electron-builder --mac --dir --x64 --arm64",
    "dist:mac": "electron-builder --mac dmg zip --x64 --arm64 --publish never"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.mytimesxr.mytimestts",
    "productName": "Mytimes TTS",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "app/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "signExecutable": false,
      "icon": "build/icon.ico",
      "artifactName": "Mytimes-TTS-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "build/icon.svg",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "artifactName": "Mytimes-TTS-${version}-macOS-${arch}.${ext}"
    },
    "dmg": {
      "title": "Mytimes TTS ${version}"
    },
    "portable": {
      "artifactName": "Mytimes-TTS-Portable-${version}-${arch}.${ext}"
    }
  }
}
